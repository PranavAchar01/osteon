# TrueFoundry AI Gateway -> AWS Bedrock. TFY_TOKEN is a TrueFoundry PAT / service-account JWT.
# TFY_GATEWAY_URL is the OpenAI-compatible base: https://<tenant>.truefoundry.cloud/api/llm/api/inference/openai/v1
TFY_TOKEN=
TFY_GATEWAY_URL=https://<tenant>.truefoundry.cloud/api/llm/api/inference/openai/v1
OTEL_EXPORTER_OTLP_ENDPOINT=
OSTEON_TRACE_DIR=./traces
OSTEON_DEADLINE_MS=20000
